# ---- Database (SQLite, zero-config) ----
# Path to the SQLite file (relative to apps/api, or absolute). Created on first run.
DATABASE_PATH=./data/api-monitor.sqlite

# ---- API (NestJS) ----
API_PORT=3000
NODE_ENV=development

# ---- Monitoring targets ----
# Comma-separated list of URLs to ping periodically. The ping service (Phase 2)
# will GET each URL and record { statusCode, latencyMs, timestamp }.
TARGET_URLS=https://httpbin.org/status/200,https://example.com

# How often to ping each URL, in seconds (defaults to 60 in the ping service)
PING_INTERVAL_SECONDS=60

# ---- Web (Vite) ----
VITE_API_URL=http://localhost:3000
